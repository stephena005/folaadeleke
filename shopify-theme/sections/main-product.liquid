{{ 'product.css' | asset_url | stylesheet_tag }}

<section class="product-page" id="product-{{ product.id }}">

  <!-- ── IMAGE GALLERY ── -->
  <div class="product-gallery">
    {%- if product.images.size > 0 -%}
      <div class="gallery-main" id="gallery-main">
        <img
          src="{{ product.featured_image | image_url: width: 1200 }}"
          alt="{{ product.featured_image.alt | escape }}"
          id="main-image"
          loading="eager"
          width="1200"
          height="{{ 1200 | divided_by: product.featured_image.aspect_ratio | round }}"
        />
      </div>

      {%- if product.images.size > 1 -%}
        <div class="gallery-thumbs" id="gallery-thumbs">
          {%- for image in product.images -%}
            <button
              class="thumb-btn{% if forloop.first %} active{% endif %}"
              data-src="{{ image | image_url: width: 1200 }}"
              data-alt="{{ image.alt | escape }}"
              aria-label="View image {{ forloop.index }}"
            >
              <img
                src="{{ image | image_url: width: 200 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="200"
                height="{{ 200 | divided_by: image.aspect_ratio | round }}"
              />
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="gallery-main gallery-placeholder">
        <span>{{ product.title }}</span>
      </div>
    {%- endif -%}
  </div>

  <!-- ── PRODUCT DETAILS ── -->
  <div class="product-details">

    <!-- Breadcrumb -->
    <p class="product-breadcrumb">
      <a href="https://shop.folaadeleke.com/">Shop</a>
      <span>/</span>
      <span>{{ product.title }}</span>
    </p>

    <!-- Title -->
    <h1 class="product-title">{{ product.title }}</h1>

    <!-- Price -->
    <p class="product-price" id="product-price">
      {%- if product.compare_at_price > product.price -%}
        <span class="price-original">{{ product.compare_at_price | money }}</span>
        <span class="price-sale">{{ product.price | money }}</span>
      {%- else -%}
        {{ product.price | money }}
      {%- endif -%}
    </p>

    <!-- Size selector -->
    {%- assign size_option = nil -%}
    {%- for option in product.options_with_values -%}
      {%- if option.name == 'Size' -%}
        {%- assign size_option = option -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if size_option -%}
      <div class="product-spec-row product-size-row">
        <span class="spec-label">Size</span>
        <div class="size-picker" id="size-picker">
          {%- for value in size_option.values -%}
            {%- assign variant_for_size = nil -%}
            {%- for v in product.variants -%}
              {%- for opt in v.options -%}
                {%- if opt == value -%}
                  {%- assign variant_for_size = v -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endfor -%}
            <button
              type="button"
              class="size-btn{% if forloop.first %} selected{% endif %}"
              data-variant-id="{{ variant_for_size.id }}"
              data-price="{{ variant_for_size.price }}"
              data-size="{{ value | escape }}"
              data-available="{{ variant_for_size.available }}"
            >{{ value }}</button>
          {%- endfor -%}
        </div>
      </div>
      {%- if product.handle == 'loud-celebration' -%}
        {%- assign dim_a1 = '594 × 594 mm / 23.4 × 23.4 in' -%}
        {%- assign dim_a2 = '500 × 500 mm / 19.7 × 19.7 in' -%}
      {%- else -%}
        {%- assign dim_a1 = product.metafields.custom.a1_dimensions | default: '594 × 841 mm / 23.4 × 33.1 in' -%}
        {%- assign dim_a2 = product.metafields.custom.a2_dimensions | default: '420 × 594 mm / 16.5 × 23.4 in' -%}
      {%- endif -%}
      <div class="product-spec-row">
        <span class="spec-label">Dimensions</span>
        <span class="spec-value" id="size-dimensions">
          {%- case size_option.values.first -%}
            {%- when 'A1' -%}{{ dim_a1 }}
            {%- when 'A2' -%}{{ dim_a2 }}
            {%- else -%}{{ size_option.values.first }}
          {%- endcase -%}
        </span>
      </div>
    {%- else -%}
      <div class="product-spec-row">
        <span class="spec-label">Size</span>
        <span class="spec-value">A1 — 594 × 841 mm / 23.4 × 33.1 in</span>
      </div>
    {%- endif -%}

    <div class="product-spec-row">
      <span class="spec-label">Edition</span>
      <span class="spec-value">
        {%- if product.metafields.custom.edition != blank -%}
          {{ product.metafields.custom.edition }}
        {%- else -%}
          Limited Edition
        {%- endif -%}
      </span>
    </div>

    <!-- Divider -->
    <hr class="product-rule" />

    <!-- Add to Cart Form -->
    {%- form 'product', product, id: 'product-form', novalidate: 'novalidate' -%}
      <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}" />

      {%- if product.available -%}
        <button
          type="submit"
          class="btn-primary"
          id="add-to-cart-btn"
          {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
        >
          {%- if product.selected_or_first_available_variant.available -%}
            Add to Cart
          {%- else -%}
            Sold Out
          {%- endif -%}
        </button>
      {%- else -%}
        <button type="button" class="btn-primary" disabled>Sold Out</button>
      {%- endif -%}

    {%- endform -%}

    <!-- Description -->
    {%- if product.description != blank -%}
      <div class="product-description">
        {{ product.description }}
      </div>
    {%- endif -%}

    <!-- Shipping / Details accordion -->
    <div class="product-accordion">
      <button class="accordion-trigger" aria-expanded="false" data-accordion="shipping">
        <span>Shipping & Delivery</span>
        <span class="accordion-icon">+</span>
      </button>
      <div class="accordion-body" id="accordion-shipping" hidden>
        <p>Prints are shipped flat, wrapped in acid-free tissue, and packaged in a rigid mailer. Dispatch within 3–5 business days. Tracked shipping worldwide.</p>
      </div>

<button class="accordion-trigger" aria-expanded="false" data-accordion="returns">
        <span>Returns</span>
        <span class="accordion-icon">+</span>
      </button>
      <div class="accordion-body" id="accordion-returns" hidden>
        <p>Each print is made to order and part of a limited edition. We take great care with every order. If your print arrives damaged or not as described, please contact us within 7 days of receipt and we will make it right.</p>
      </div>

      <button class="accordion-trigger" aria-expanded="false" data-accordion="sizeguide">
        <span>Size Guide</span>
        <span class="accordion-icon">+</span>
      </button>
      <div class="accordion-body" id="accordion-sizeguide" hidden>
        <table class="size-guide-table">
          <thead>
            <tr>
              <th>Format</th>
              <th colspan="2">Dimensions</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>A1</td>
              <td colspan="2">{{ dim_a1 }}</td>
            </tr>
            <tr>
              <td>A2</td>
              <td colspan="2">{{ dim_a2 }}</td>
            </tr>
          </tbody>
        </table>
        {%- if product.handle == 'loud-celebration' -%}
          <p class="size-guide-note">Prints are unframed. These are custom square formats — we recommend consulting a framing studio for a made-to-measure frame.</p>
        {%- else -%}
          <p class="size-guide-note">Prints are unframed. Both sizes correspond to standard international paper formats — frames are widely available from most framing studios.</p>
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

<script>
  // ── Thumbnail gallery swap ──
  var thumbs = document.querySelectorAll('.thumb-btn');
  var mainImg = document.getElementById('main-image');

  thumbs.forEach(function(btn) {
    btn.addEventListener('click', function() {
      mainImg.src = btn.dataset.src;
      mainImg.alt = btn.dataset.alt;
      thumbs.forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
    });
  });

  // ── Size picker ──
  var sizeBtns = document.querySelectorAll('.size-btn');
  var variantInput = document.getElementById('variant-id');
  var priceEl = document.getElementById('product-price');
  var dimensionsEl = document.getElementById('size-dimensions');

  var sizeDimensions = {
    'A1': 'A1 — {{ dim_a1 }}',
    'A2': 'A2 — {{ dim_a2 }}'
  };

  function formatMoney(cents) {
    return '£' + (cents / 100).toFixed(2);
  }

  var addToCartBtn = document.getElementById('add-to-cart-btn');

  sizeBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      sizeBtns.forEach(function(b) { b.classList.remove('selected'); });
      btn.classList.add('selected');
      if (variantInput) variantInput.value = btn.dataset.variantId;
      if (priceEl) priceEl.textContent = formatMoney(parseInt(btn.dataset.price, 10));
      if (dimensionsEl) dimensionsEl.textContent = sizeDimensions[btn.dataset.size] || btn.dataset.size;
      if (addToCartBtn) {
        var available = btn.dataset.available === 'true';
        addToCartBtn.disabled = !available;
        addToCartBtn.textContent = available ? 'Add to Cart' : 'Sold Out';
      }
    });
  });

  // ── Accordion ──
  var triggers = document.querySelectorAll('.accordion-trigger');

  triggers.forEach(function(trigger) {
    trigger.addEventListener('click', function() {
      var key = trigger.dataset.accordion;
      var body = document.getElementById('accordion-' + key);
      var expanded = trigger.getAttribute('aria-expanded') === 'true';
      var icon = trigger.querySelector('.accordion-icon');

      trigger.setAttribute('aria-expanded', !expanded);
      body.hidden = expanded;
      icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "class": "section-product",
  "settings": []
}
{% endschema %}
